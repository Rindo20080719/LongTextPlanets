# ==================== 必須 ====================
ANTHROPIC_API_KEY=sk-ant-...

# ==================== Stripe（カード払い） ====================
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe で商品・価格を作成して取得する Price ID
# ダッシュボード → 製品 → 「長文プラネット サブスク ¥500/月」を作成 → 価格ID
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ダッシュボード → 製品 → 「回数券 5回分 ¥300」を作成（1回払い）→ 価格ID
STRIPE_TICKET_PRICE_ID=price_...

# ==================== PayPay（QR払い） ====================
# https://developer.paypay.ne.jp/
PAYPAY_API_KEY=...
PAYPAY_API_SECRET=...
PAYPAY_MERCHANT_ID=...

# ==================== その他 ====================
# 本番デプロイ時は実際のドメインに変更（Stripeリダイレクト先に使用）
BASE_URL=http://localhost:3000

# 本番時は production に変更（PayPay sandbox/本番切替）
NODE_ENV=development
